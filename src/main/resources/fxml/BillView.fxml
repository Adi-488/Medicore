<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.hospital_management.controller.BillController"
      styleClass="page-container" spacing="18">

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Billing" styleClass="page-title"/>
                <Label fx:id="lblBillCount" text="" styleClass="page-count-badge"/>
            </HBox>
            <Label text="Manage invoices, payments, and revenue" styleClass="page-subtitle"/>
        </VBox>
        <Button text="＋ New Bill" styleClass="btn-primary" onAction="#onAddBill"/>
    </HBox>

    <!-- Summary Bar -->
    <HBox fx:id="summaryBar" styleClass="summary-bar" alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="Total Revenue" styleClass="summary-label"/>
            <Label fx:id="lblTotalRevenue" text="₹0" styleClass="summary-value"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Collected" styleClass="summary-label"/>
            <Label fx:id="lblCollected" text="₹0" styleClass="summary-value, summary-value-green"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Pending" styleClass="summary-label"/>
            <Label fx:id="lblPending" text="₹0" styleClass="summary-value, summary-value-orange"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Total Bills" styleClass="summary-label"/>
            <Label fx:id="lblTotalBills" text="0" styleClass="summary-value"/>
        </VBox>
    </HBox>

    <!-- Toolbar: Filters -->
    <HBox styleClass="toolbar-row" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Search by patient name..."
                   styleClass="search-field" HBox.hgrow="SOMETIMES"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="filterAll" text="All" styleClass="filter-button, filter-button-active"
                onAction="#onFilterAll"/>
        <Button fx:id="filterPending" text="Pending" styleClass="filter-button"
                onAction="#onFilterPending"/>
        <Button fx:id="filterPaid" text="Paid" styleClass="filter-button"
                onAction="#onFilterPaid"/>
        <Button fx:id="filterOverdue" text="Overdue" styleClass="filter-button"
                onAction="#onFilterOverdue"/>
    </HBox>

    <!-- Bill Table -->
    <VBox styleClass="section-card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="billTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colPatient" text="Patient" prefWidth="160"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="220"/>
                <TableColumn fx:id="colAmount" text="Amount" prefWidth="120"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colPayment" text="Payment" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
            </columns>
        </TableView>
    </VBox>

</VBox>
