<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.hospital_management.controller.AppointmentController"
      styleClass="page-container" spacing="18">

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Appointments" styleClass="page-title"/>
                <Label fx:id="lblAppointmentCount" text="" styleClass="page-count-badge"/>
            </HBox>
            <Label text="Schedule and manage all appointments" styleClass="page-subtitle"/>
        </VBox>
        <Button text="＋ New Appointment" styleClass="btn-primary" onAction="#onAddAppointment"/>
    </HBox>

    <!-- Toolbar: Filters -->
    <HBox styleClass="toolbar-row" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Search by patient or doctor..."
                   styleClass="search-field" HBox.hgrow="SOMETIMES"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="filterAll" text="All" styleClass="filter-button, filter-button-active"
                onAction="#onFilterAll"/>
        <Button fx:id="filterScheduled" text="Scheduled" styleClass="filter-button"
                onAction="#onFilterScheduled"/>
        <Button fx:id="filterCompleted" text="Completed" styleClass="filter-button"
                onAction="#onFilterCompleted"/>
        <Button fx:id="filterCancelled" text="Cancelled" styleClass="filter-button"
                onAction="#onFilterCancelled"/>
    </HBox>

    <!-- Appointment Table -->
    <VBox styleClass="section-card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colPatient" text="Patient" prefWidth="150"/>
                <TableColumn fx:id="colDoctor" text="Doctor" prefWidth="160"/>
                <TableColumn fx:id="colDepartment" text="Department" prefWidth="140"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                <TableColumn fx:id="colTime" text="Time" prefWidth="80"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                <TableColumn fx:id="colNotes" text="Notes" prefWidth="160"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="140"/>
            </columns>
        </TableView>
    </VBox>

</VBox>
